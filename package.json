{
  "name": "espy-project-monorepo",
  "private": true,
  "scripts": {
    "admin:build": "cd apps/admin_app && flutter build web --release",
    "user:build": "cd apps/user_app && flutter build web --release",
    "frontend:deploy": "powershell -File ./apps/deploy_pwa.ps1",
    "backend:deploy": "firebase deploy --only functions,firestore:rules,storage,dataconnect",
    "backend:sync": "firebase dataconnect:sdk:generate",
    "deploy:all": "npm run frontend:deploy && npm run backend:deploy"
  }
}
