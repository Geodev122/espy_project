{
  "$schema": "https://raw.githubusercontent.com/firebase/firebase-tools/master/schema/firebase.json",
  "hosting": [
    {
      "target": "admin-dashboard",
      "public": "apps/admin_pwa/build/web",
      "ignore": [
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "visitor-app",
      "public": "apps/visitor_app/build/web",
      "ignore": [
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "pro-app",
      "public": "apps/build/web",
      "ignore": [
        "**/node_modules/**"
      ],
      "rewrites": [
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  }
}
