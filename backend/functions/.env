# ============================================================
# HOPE BEARER AWARD - CLOUD FUNCTIONS ENVIRONMENT VARIABLES
# ============================================================

# ============================================================
# WHISHPAY CONFIGURATION (Production)
# ============================================================
# Production API Endpoint
WHISH_API_URL=https://api.whish.money/itel-service/api

# Website URLs (comma-separated)
WHISH_WEBSITE_URL=hopebearer-award.com,hope-support-suit.web.app

# Base URL for callbacks

# WhishPay Credentials (from configure-whishpay-production.ps1)
WHISHPAY_SECRET=23cfc205ed0d4aba83df6b12b0bbd4a1
WHISHPAY_CHANNEL=15462415
WHISHPAY_WEBSITE_URL=hopebearer-award.com
WHISHPAY_ENVIRONMENT=production

# For Sandbox/Testing (comment out production, uncomment these):
# WHISHPAY_ENVIRONMENT=sandbox
# WHISH_API_URL=https://api.sandbox.whish.money/itel-service/api
# WHISHPAY_SECRET=your_sandbox_secret
# WHISHPAY_CHANNEL=your_sandbox_channel

# ============================================================
# SMTP/EMAIL CONFIGURATION
# ============================================================
# Gmail account for sending emails
GMAIL_USER=geo.elnajjar@gmail.com

# Gmail App Password - MUST be set via Firebase Secrets:
# firebase functions:secrets:set GMAIL_APP_PASSWORD
# GMAIL_APP_PASSWORD=your_app_password_here

# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================
# Note: GCLOUD_PROJECT is reserved and set automatically by Firebase
ENVIRONMENT=production

# For Development:
# ENVIRONMENT=development

# ============================================================
# CALLBACK URLS
# ============================================================
WHISHPAY_SUCCESS_URL=https://hopebearer-award.com/#/payment/success
WHISHPAY_CANCEL_URL=https://hopebearer-award.com/#/payment/cancelled
WHISHPAY_WEBHOOK_URL=https://us-central1-hope-bearer-award.cloudfunctions.net/whishPayWebhook
BASE_URL=https://hopebearer-award.com
SUPPORT_BASE_URL=https://hope-bearer-award-support.web.app
