{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      ".read": "auth != null",
      ".write": "false"
    },
    "users": {
      "$uid": {
        ".read": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).exists())"
      }
    },
    "app_config": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "activity_logs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "committee": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "committeeMembers": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "honorees": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "sponsors": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "sponsorshipTiers": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "mail": {
      "$mailId": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    "emailQueue": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "seatBookings": {
      ".read": true,
      "$bookingId": {
        ".write": "!data.exists() || auth != null",
        ".validate": "!data.exists() || (auth != null && (data.child('uid').val() === auth.uid || root.child('admins').child(auth.uid).exists()))"
      }
    },
    "bookings": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      "$bookingId": {
        ".read": "auth != null && (data.child('uid').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null"
      }
    },
    "payments": {
      "whishpay": {
        ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    "directory_professionals": {
      ".read": true,
      "$profId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists()"
      },
      ".indexOn": [
        "type",
        "userId",
        "is_approved",
        "is_active",
        "category_id",
        "governorate_id"
      ]
    },
    "directory_institutions": {
      ".read": true,
      "$instId": {
        ".write": "auth != null && (!data.exists() || data.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists()"
      },
      ".indexOn": [
        "type",
        "userId",
        "is_approved",
        "is_active",
        "category_id",
        "governorate_id"
      ]
    },
    "directory_visitors": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth != null",
      ".indexOn": [
        "whatsapp"
      ]
    },
    "directory_categories": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_governorates": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_cities": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_packages": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_purchases": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_settings": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()"
    },
    "directory_interactions": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": true
    },
    "directory_favorites": {
      ".indexOn": ["userId"],
      "$docId": {
        ".read": "auth != null && (data.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (newData.child('userId').val() === auth.uid || root.child('admins').child(auth.uid).exists())"
      }
    },
    "directory_payments": {
      ".read": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())"
    },
    "directory_admin_logs": {
      ".read": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())"
    },
    "directory_membership_transactions": {
      ".read": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())",
      ".write": "auth != null && (auth.token.role === 'admin' || root.child('admins').child(auth.uid).exists())"
    }
  }
}