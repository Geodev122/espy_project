rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.email == 'geo.elnajjar@gmail.com'
      );
    }

    // PROFILE IMAGES: Publicly readable, owner can write.
    match /profile_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // VERIFICATION DOCUMENTS: Owner can write, only Admin can read.
    match /verification_docs/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // SERVICE IMAGES: Public read, provider can write.
    match /service_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // DEFAULT: Deny all.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
