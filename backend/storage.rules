rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper: admin check ─────────────────────────────────────────────────
    // Defined first so all rules below can reference it safely.
    function isAdmin() {
      return request.auth != null &&
             (request.auth.token.admin == true ||
              request.auth.token.role == 'admin' ||
              request.auth.token.isAdmin == true ||
              request.auth.token.superAdmin == true ||
              request.auth.token.email == 'geo.elnajjar@gmail.com');
    }

    // ── Root-level image files ───────────────────────────────────────────────
    match /{fileName} {
      allow read: if fileName.matches('.*\\.(jpg|jpeg|png|gif|svg)$');
      allow write: if isAdmin();
    }

    // Allow public read access to honoree and sponsor images
    match /honorees/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sponsors/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Allow public read access to sponsorship tier documents
    match /sponsorshipTiers/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Allow public read access to social media posts
    match /social-posts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Profile images for users
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Service images
    match /directory_services/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                     && request.resource.size < 10 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
    }

    // Profile images for professionals and providers
    match /profiles/professionals/{fileName} {
      allow read: if true; // Public read for directory visibility
      allow write: if request.auth != null 
                     && request.resource.size < 10 * 1024 * 1024 // Max 10MB
                     && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    match /profiles/providers/{fileName} {
      allow read: if true; // Public read for directory visibility
      allow write: if request.auth != null 
                     && request.resource.size < 10 * 1024 * 1024 // Max 10MB
                     && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    // Allow public uploads for nomination attachments, with size and type checks
    match /nominations/{nominationId}/{fileName} {
      allow read: if request.auth != null; // Only admins can read attachments
      allow create: if request.resource.size < 10 * 1024 * 1024 // Max 10MB
                      && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('application/pdf'));
    }

    // Allow public uploads for booking identification documents
    match /bookings/{allPaths=**} {
      allow read: if true;
      allow create: if request.resource.size < 50 * 1024 * 1024 // Max 50MB
                      && (
                        request.resource.contentType.matches('image/.*') 
                        || request.resource.contentType.matches('application/pdf')
                        || request.resource.contentType == 'image/heic' 
                        || request.resource.contentType == 'image/heif'
                        || request.resource.contentType == 'application/octet-stream'
                      );
      allow update, delete: if isAdmin();
    }

    // Allow public uploads for payment confirmation documents
    match /payment-confirmations/{allPaths=**} {
      allow read: if true;
      allow create: if request.resource.size < 10 * 1024 * 1024 // Max 10MB
                      && (
                        request.resource.contentType.matches('image/.*')
                        || request.resource.contentType.matches('application/pdf')
                      );
      allow update, delete: if isAdmin();
    }

    // Tickets folder - admin writes, public reads with ticket
    match /tickets/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Professional files (licenses, profile pictures, documents) ───────────
    match /professionals/{professionalId}/{allPaths=**} {
      allow read: if allPaths.matches('profile\\..*');
      allow read, write: if request.auth != null &&
                            request.auth.uid == professionalId &&
                            request.resource.size < 20 * 1024 * 1024 &&
                            (request.resource.contentType.matches('image/.*') ||
                             request.resource.contentType.matches('application/pdf'));
      allow read, write, delete: if isAdmin();
    }
    
    // ── Service provider files (documents, logos, images) ───────────────────
    match /service_providers/{providerId}/{allPaths=**} {
      allow read: if allPaths.matches('images/organization_logo\\..*');
      allow read, write: if request.auth != null
                            && request.auth.uid == providerId
                            && request.resource.size < 20 * 1024 * 1024
                            && (request.resource.contentType.matches('image/.*') || 
                                request.resource.contentType.matches('application/pdf'));
      allow read, write, delete: if isAdmin();
    }

    // ── NEW: Document folders for wizards (with 'documents/' prefix) ──────────
    match /documents/professionals/{fileName} {
      allow read: if request.auth != null && fileName[0:request.auth.uid.size()] == request.auth.uid;
      allow write: if request.auth != null &&
                            fileName[0:request.auth.uid.size()] == request.auth.uid &&
                            request.resource.size < 20 * 1024 * 1024 &&
                            (request.resource.contentType.matches('image/.*') ||
                             request.resource.contentType.matches('application/pdf.*') ||
                             request.resource.contentType.matches('application/msword.*') ||
                             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document.*'));
      allow read, write, delete: if isAdmin();
    }

    match /documents/providers/{fileName} {
      allow read: if request.auth != null && fileName[0:request.auth.uid.size()] == request.auth.uid;
      allow write: if request.auth != null &&
                            fileName[0:request.auth.uid.size()] == request.auth.uid &&
                            request.resource.size < 20 * 1024 * 1024 &&
                            (request.resource.contentType.matches('image/.*') ||
                             request.resource.contentType.matches('application/pdf.*') ||
                             request.resource.contentType.matches('application/msword.*') ||
                             request.resource.contentType.matches('application/vnd.openxmlformats-officedocument.wordprocessingml.document.*'));
      allow read, write, delete: if isAdmin();
    }
    
    // ── Temporary uploads ────────────────────────────────────────────────────
    match /temp_uploads/{userId}/{fileName} {
      allow read, write, delete: if request.auth != null && 
                                     request.auth.uid == userId &&
                                     request.resource.size < 20 * 1024 * 1024 &&
                                     (request.resource.contentType.matches('image/.*') || 
                                      request.resource.contentType.matches('application/pdf'));
      allow read, write, delete: if isAdmin();
    }

    // ── Generic profiles folder ──────────────────────────────────────────────
    match /profiles/{folder}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                      && fileName.matches(request.auth.uid + '_.*')
                      && request.resource.size < 20 * 1024 * 1024
                      && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && fileName.matches(request.auth.uid + '_.*');
    }

    // ── Deny all unmatched paths ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
